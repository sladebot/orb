# Option 1: Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Claude Code OAuth token — run `claude setup-token` to generate
ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...

# OpenAI API key (from platform.openai.com)
OPENAI_API_KEY=sk-...

# Ollama model to use for all local tiers (default: per-tier defaults in types.py)
# OLLAMA_MODEL=qwen3.5:9b
